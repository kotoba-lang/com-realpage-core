// Realpage_core clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace realpage_core {

    entity Listing {
        id: string @unique
        propertyId: string
        price: float
        status: string
        listedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Property {
        id: string @unique
        address: string
        beds: integer
        baths: float
        sqft: integer
        lat: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Agent {
        id: string @unique
        name: string
        license: string
        brokerage: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Transaction {
        id: string @unique
        listingId: string
        buyerId: string
        salePrice: float
        closedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Lease {
        id: string @unique
        propertyId: string
        tenantId: string
        rent: float
        startsAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Tenant {
        id: string @unique
        name: string
        email: string
        phone: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
